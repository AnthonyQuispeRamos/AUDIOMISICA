    public static void mostrarProductos(ArrayList<String> productos, ArrayList<Double> precios, String nombreCategoria) {
        System.out.println("----------------------------");
        System.out.println("===== " + nombreCategoria + " =====");
        System.out.println("----------------------------");
        for (int i = 0; i < productos.size(); i++) {
            System.out.println((i + 1) + ". " + productos.get(i) + " - S/ " + precios.get(i));
        }
        System.out.println("Seleccione un producto (0 para cancelar): ");
        int eleccion = escaner.nextInt();
        if (eleccion >= 1 && eleccion <= productos.size()) {
            carritoNombres.add(productos.get(eleccion - 1));
            carritoPrecios.add(precios.get(eleccion - 1));
            total += precios.get(eleccion - 1);
            System.out.println("Producto agregado correctamente ✔️");
            System.out.println("Total acumulado: S/ " + total);
        } else if (eleccion == 0) {
            System.out.println("Operacion cancelada");
        } else {
            System.out.println("Opcion no valida");
        }
    }
    public static void verCarrito() {
        if (carritoNombres.isEmpty()) {
            System.out.println("El carrito esta vacio");
            return;
        }
        System.out.println("===== CARRITO DE COMPRAS =====");
        double subtotal = 0;
        for (int i = 0; i < carritoNombres.size(); i++) {
            System.out.println((i + 1) + ". " + carritoNombres.get(i) + " - S/ " + carritoPrecios.get(i));
            subtotal += carritoPrecios.get(i);
        }
        System.out.println("----------------------------");
        System.out.println("TOTAL: S/ " + subtotal);
        System.out.println("----------------------------");
        System.out.println("1. Confirmar compra");
        System.out.println("2. Vaciar carrito");
        System.out.println("3. Volver al menu");
        int opcion = escaner.nextInt();
        if (opcion == 1) {
            System.out.println("Compra realizada con exito. Total: S/ " + subtotal);
            carritoNombres.clear();
            carritoPrecios.clear();
            total = 0;
        } else if (opcion == 2) {
            carritoNombres.clear();
            carritoPrecios.clear();
            total = 0;
            System.out.println("Carrito vaciado");
        }
    }
