                case 3:
                    crudEliminar(estuches, preciosEstuches, "ESTUCHES");
                    break;
                case 4:
                    crudEliminar(cuerdas, preciosCuerdas, "CUERDAS");
                    break;
                case 5:
                    crudEliminar(guitarrasAcusticas, preciosGuitarrasAcusticas, "GUITARRAS ACUSTICAS");
                    break;
                case 6:
                    crudEliminar(guitarrasElectricas, preciosGuitarrasElectricas, "GUITARRAS ELECTRICAS");
                    break;
                case 7:
                    crudEliminar(bajosMedios, preciosBajosMedios, "BAJOS MEDIOS");
                    break;
                case 8:
                    crudEliminar(pianos, preciosPianos, "PIANOS");
                    break;
                case 9:
                    crudEliminar(baterias, preciosBaterias, "BATERIAS");
                    break;
                case 10:
                    crudEliminar(microfonos, preciosMicrofonos, "MICROFONOS");
                    break;
                case 11:
                    System.out.println("Volviendo al menu principal...");
                    break;
                default:
                    System.out.println("Opcion no valida");
            }
        } while (opcion != 11);
    }
    public static void crudEliminar(ArrayList<String> lista, ArrayList<Double> precios, String nombreCategoria) {
        System.out.println("--- ELIMINAR PRODUCTO DE " + nombreCategoria + " ---");
        imprimirListaConPrecios(lista, precios);
        System.out.println("Ingrese la posicion a eliminar:");
        int pos = escaner.nextInt();
        escaner.nextLine();
        if (pos >= 0 && pos < lista.size()) {
            String productoEliminado = lista.get(pos);
            lista.remove(pos);
            precios.remove(pos);
            System.out.println("Producto " + productoEliminado + "eliminado correctamente ✔️");
        } else {
            System.out.println("Posicion no valida ✖️");
        }
    }
    public static void imprimirListaConPrecios(ArrayList<String> lista, ArrayList<Double> precios) {
        if (lista.isEmpty()) {
            System.out.println("No hay productos en esta categoria");
            return;
        }
        for (int i = 0; i < lista.size(); i++) {
            System.out.println(i + ". " + lista.get(i) + " - S/ " + precios.get(i));
        }
    }
